# 可选：填入后启用 Anthropic LLM 增强解析（旧接口保留）
ANTHROPIC_API_KEY=

# 推荐：填入后启用 /api/voice-command 的 GLM Function Calling 解析（智谱 AI）
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4
LLM_TIMEOUT=5000

# 推荐：配置后启用真实图像生成（DALL-E 兼容 API，含智谱 BigModel）
# 未配置时，复杂对象（房子/树/动物/场景）会返回"未配置图像生成服务"错误提示；
# 用户可改说"用简单图形画房子"等以走预置几何场景。
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.openai.com
IMAGE_MODEL=dall-e-3

# 必填：JWT 签名密钥（启动时自动校验，未设置则首启随机生成并写入 .env.local）
AUTH_JWT_SECRET=
